{
  "name": "ganbaru-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:native-host": "cargo build --bin ganbaru-ai-native-messaging",
    "setup:brave-extension": "node apps/client/scripts/setup-brave-extension.mjs",
    "audit:deps": "pnpm audit --audit-level low",
    "audit:rust": "cargo audit",
    "check": "turbo check && cargo fmt --check && cargo clippy --workspace -- -D warnings",
    "editor-check": "pnpm --dir apps/client run editor-check",
    "test": "turbo test && cargo test --workspace",
    "validate": "pnpm -w run audit:deps && pnpm -w run audit:rust && pnpm check && pnpm test && pnpm -w run editor-check"
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": "^22.12.0 || ^24.0.0",
    "pnpm": ">=11 <12"
  }
}
