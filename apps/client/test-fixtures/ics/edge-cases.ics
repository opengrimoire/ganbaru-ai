SUMMARY:Event without DTEND or DURATION
END:VEVENT
BEGIN:VEVENT
UID:duration-only@example.com
DTSTAMP:20260401T120000Z
DTSTART:20260602T140000Z
DURATION:PT2H30M
SUMMARY:Event with DURATION instead of DTEND
END:VEVENT
BEGIN:VEVENT
UID:floating-time@example.com
DTSTAMP:20260401T120000Z
DTSTART:20260603T140000
DTEND:20260603T150000
SUMMARY:Floating time with no TZID and no Z
END:VEVENT
BEGIN:VEVENT
UID:exdate-event@example.com
DTSTAMP:20260401T120000Z
DTSTART;TZID=America/New_York:20260415T100000
DTEND;TZID=America/New_York:20260415T103000
RRULE:FREQ=DAILY;COUNT=5
EXDATE;TZID=America/New_York:20260417T100000
SUMMARY:Daily event with one excluded date
END:VEVENT
BEGIN:VEVENT
UID:rdate-event@example.com
DTSTAMP:20260401T120000Z
DTSTART:20260701T100000Z
DTEND:20260701T110000Z
RDATE:20260705T100000Z,20260712T100000Z
SUMMARY:Event with explicit RDATEs
END:VEVENT
BEGIN:VEVENT
UID:unknown-tzid@example.com
DTSTAMP:20260401T120000Z
DTSTART;TZID=Bogus/Made-Up-Zone:20260801T100000
DTEND;TZID=Bogus/Made-Up-Zone:20260801T110000
SUMMARY:Event with unknown TZID
END:VEVENT
BEGIN:VEVENT
UID:alarm-repeat@example.com
DTSTAMP:20260401T120000Z
DTSTART:20260901T140000Z
DTEND:20260901T150000Z
SUMMARY:Event with VALARM REPEAT and DURATION
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:Repeating reminder
TRIGGER:-PT10M
REPEAT:3
DURATION:PT5M
END:VALARM
END:VEVENT
BEGIN:VEVENT
UID:custom-x-props@example.com
DTSTAMP:20260401T120000Z
DTSTART:20261001T120000Z
DTEND:20261001T130000Z
SUMMARY:Event with X-* properties
X-CUSTOM-FIELD:custom-value-123
X-ANOTHER-FIELD:another-value
END:VEVENT
