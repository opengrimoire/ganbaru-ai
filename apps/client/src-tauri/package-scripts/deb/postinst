#!/bin/sh
set -eu

source_key="/usr/lib/ganbaru-ai/package-repo/ganbaru-ai-package-repo.asc"
keyring="/usr/share/keyrings/ganbaru-ai-package-repo.asc"
source_list="/etc/apt/sources.list.d/ganbaru-ai.sources"
repo_url="https://opengrimoire.github.io/ganbaru-ai/packages/apt"

if [ -r "$source_key" ]; then
  install -D -m 0644 "$source_key" "$keyring"
  mkdir -p /etc/apt/sources.list.d
  cat > "$source_list" <<EOF
Types: deb
URIs: $repo_url
Suites: stable
Components: main
Architectures: amd64
Signed-By: $keyring
EOF
fi

exit 0
