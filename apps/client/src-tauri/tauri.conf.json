{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ganbaru-ai",
  "mainBinaryName": "ganbaru-ai",
  "version": "0.1.5",
  "identifier": "org.opengrimoire.ganbaru-ai",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420/__ganbaru-ai_dev_ready",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ganbaru AI",
        "width": 1200,
        "height": 800,
        "minWidth": 280,
        "minHeight": 180,
        "maximized": true,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' https://www.youtube.com https://s.ytimg.com",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost http://127.0.0.1:* http://localhost:*",
        "media-src": "'self' http://127.0.0.1:* http://localhost:*",
        "font-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "object-src": "'none'",
        "frame-src": "http://127.0.0.1:* http://localhost:* https://www.youtube.com https://www.youtube-nocookie.com",
        "base-uri": "'none'",
        "form-action": "'none'"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:1420 http://127.0.0.1:1420",
        "script-src": "'self' 'unsafe-eval' http://localhost:1420 http://127.0.0.1:1420 https://www.youtube.com https://s.ytimg.com",
        "style-src": "'self' 'unsafe-inline' http://localhost:1420 http://127.0.0.1:1420",
        "img-src": "'self' asset: http://asset.localhost http://127.0.0.1:* http://localhost:* http://localhost:1420 http://127.0.0.1:1420",
        "media-src": "'self' http://127.0.0.1:* http://localhost:* http://localhost:1420 http://127.0.0.1:1420",
        "font-src": "'self' http://localhost:1420 http://127.0.0.1:1420",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 http://127.0.0.1:1420 ws://localhost:1420 ws://127.0.0.1:1420 ws://localhost:1421 ws://127.0.0.1:1421",
        "object-src": "'none'",
        "frame-src": "http://127.0.0.1:* http://localhost:* https://www.youtube.com https://www.youtube-nocookie.com",
        "base-uri": "'none'",
        "form-action": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "linux": {
      "deb": {
        "desktopTemplate": "deb.desktop.hbs"
      },
      "rpm": {
        "desktopTemplate": "deb.desktop.hbs"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
