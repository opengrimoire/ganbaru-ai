{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GanbaruAI",
  "version": "0.1.0",
  "identifier": "org.opengrimoire.ganbaruai",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420/__ganbaruai_dev_ready",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GanbaruAI",
        "width": 1200,
        "height": 800,
        "minWidth": 280,
        "minHeight": 180,
        "maximized": true,
        "decorations": false,
        "transparent": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost",
        "font-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "object-src": "'none'",
        "frame-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:1420 http://127.0.0.1:1420",
        "script-src": "'self' 'unsafe-eval' http://localhost:1420 http://127.0.0.1:1420",
        "style-src": "'self' 'unsafe-inline' http://localhost:1420 http://127.0.0.1:1420",
        "img-src": "'self' asset: http://asset.localhost http://localhost:1420 http://127.0.0.1:1420",
        "font-src": "'self' http://localhost:1420 http://127.0.0.1:1420",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 http://127.0.0.1:1420 ws://localhost:1420 ws://127.0.0.1:1420 ws://localhost:1421 ws://127.0.0.1:1421",
        "object-src": "'none'",
        "frame-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
